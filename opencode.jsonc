{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "graymatter": {
      "command": [
        "graymatter",
        "mcp",
        "serve"
      ],
      "enabled": true,
      "type": "local"
    },
    "qdrant": {
      "type": "local",
      "enabled": true,
      "disabled": true,
      "command": [
        "uvx",
        "mcp-server-qdrant"
      ],
      "env": {
        "QDRANT_LOCAL_PATH": "/home/meyverick/dev/omnicode/.qdrant",
        "COLLECTION_NAME": "references",
        "EMBEDDING_MODEL": "BAAI/bge-small-en-v1.5",
        "FASTEMBED_CACHE_PATH": "/home/meyverick/.cache/fastembed",
        "QRANT_NUM_THREADS": "1",
        "QRANT_INDEX_CONCURRENCY": "1"
      }
    }
  }
}
