{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "graymatter": {
      "command": [
        "graymatter",
        "mcp",
        "serve"
      ],
      "enabled": true,
      "type": "local"
    },
    "qdrant": {
      "type": "local",
      "enabled": true,
      "disabled": false,
      "command": [
        "sh",
        "-c",
        "QDRANT_URL=http://localhost:6333 COLLECTION_NAME=references-d4dc0a81-e297-46f7-820b-e1ce76afc50c EMBEDDING_MODEL=BAAI/bge-small-en-v1.5 FASTEMBED_CACHE_PATH=/home/meyverick/.cache/fastembed QRANT_NUM_THREADS=1 QRANT_INDEX_CONCURRENCY=1 uvx mcp-server-qdrant"
      ],
      "env": {
        "QDRANT_URL": "http://localhost:6333",
        "COLLECTION_NAME": "references-d4dc0a81-e297-46f7-820b-e1ce76afc50c",
        "EMBEDDING_MODEL": "BAAI/bge-small-en-v1.5",
        "FASTEMBED_CACHE_PATH": "/home/meyverick/.cache/fastembed",
        "QRANT_NUM_THREADS": "1",
        "QRANT_INDEX_CONCURRENCY": "1"
      }
    }
  }
}
