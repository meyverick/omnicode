{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "graymatter": {
      "command": [
        "graymatter",
        "mcp",
        "serve"
      ],
      "enabled": true,
      "type": "local"
    },
    "qdrant": {
      "type": "local",
      "enabled": true,
      "disabled": true,
      "command": [
        "uvx",
        "mcp-server-qdrant"
      ],
      "env": {
        "QDRANT_URL": "http://localhost:6333",
        "COLLECTION_NAME": "references-a48d9c2d-18b8-4a52-8d8b-3e1f06f72a3a",
        "EMBEDDING_MODEL": "BAAI/bge-small-en-v1.5",
        "FASTEMBED_CACHE_PATH": "/home/meyverick/.cache/fastembed",
        "QRANT_NUM_THREADS": "1",
        "QRANT_INDEX_CONCURRENCY": "1"
      }
    }
  }
}
