{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "graymatter": {
      "command": [
        "graymatter",
        "mcp",
        "serve"
      ],
      "enabled": true,
      "type": "local"
    },
    "qdrant": {
      "type": "local",
      "enabled": true,
      "command": [
        "uvx",
        "mcp-server-qdrant"
      ],
      "env": {
        "QDRANT_LOCAL_PATH": "/home/meyverick/dev/omnicode/.qdrant",
        "COLLECTION_NAME": "references",
        "EMBEDDING_MODEL": "sentence-transformers/all-MiniLM-L6-v2"
      }
    }
  }
}
